generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MovementType {
  DEPOSIT
  WITHDRAW
}

enum InvestmentType {
  FCI
  MONEY_MARKET
  STOCK
  ETF
  CRYPTO
  FIXED_TERM
  BOND
  OTHER
}

enum SimulationType {
  FIXED
  REAL_HISTORY
  OPTIMISTIC
  PESSIMISTIC
  CUSTOM
}

enum CashTransactionType {
  INCOME
  EXPENSE
}

enum FundingType {
  CASH_TO_INVESTMENT
  INVESTMENT_TO_CASH
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  accounts     Account[]
  cashAccounts CashAccount[]
  categories   Category[]
  transfers    CashTransfer[]
  fundings     AccountFunding[]
  budgets      Budget[]
}

model Account {
  id             String             @id @default(cuid())
  userId         String
  name           String
  description    String?
  currency       String             @default("ARS")
  investmentType InvestmentType
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  movements      Movement[]
  performances   DailyPerformance[]
  simulations    Simulation[]
  fundings       AccountFunding[]

  @@index([userId])
}

model Movement {
  id          String       @id @default(cuid())
  accountId   String
  type        MovementType
  amount      Float
  date        DateTime
  description String?
  fundingId   String?
  createdAt   DateTime     @default(now())
  account     Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  funding     AccountFunding? @relation(fields: [fundingId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([date])
  @@index([fundingId])
}

model DailyPerformance {
  id                 String   @id @default(cuid())
  accountId          String
  date               DateTime
  dailyReturnPercent Float
  dailyProfit        Float
  shareValue         Float
  notes              String?
  createdAt          DateTime @default(now())
  account            Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, date])
  @@index([accountId])
  @@index([date])
}

model Simulation {
  id                  String             @id @default(cuid())
  accountId           String
  name                String
  simulationType      SimulationType
  capitalInitial      Float
  monthlyContribution Float              @default(0)
  annualRate          Float?
  years               Int
  createdAt           DateTime           @default(now())
  account             Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  results             SimulationResult[]

  @@index([accountId])
}

model SimulationResult {
  id           String     @id @default(cuid())
  simulationId String
  day          Int
  capital      Float
  profit       Float
  dailyRate    Float
  simulation   Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)

  @@index([simulationId])
}

model CashAccount {
  id             String        @id @default(cuid())
  userId         String
  name           String
  description    String?
  currency       String        @default("ARS")
  openingBalance Float         @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  transfersOut   CashTransfer[] @relation("TransferOut")
  transfersIn    CashTransfer[] @relation("TransferIn")
  fundings       AccountFunding[]
  budgets        Budget[]

  @@index([userId])
}

model Category {
  id           String              @id @default(cuid())
  userId       String
  parentId     String?
  name         String
  type         CashTransactionType
  color        String?
  icon         String?
  createdAt    DateTime            @default(now())
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       Category?           @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children     Category[]          @relation("CategoryHierarchy")
  transactions Transaction[]
  budgets      BudgetCategory[]

  @@index([userId])
  @@index([parentId])
  @@index([type])
}

model Transaction {
  id            String              @id @default(cuid())
  cashAccountId String
  categoryId    String
  type          CashTransactionType
  amount        Float
  date          DateTime
  description   String?
  transferId    String?
  fundingId     String?
  relatedExpenseId String?
  createdAt     DateTime            @default(now())
  cashAccount   CashAccount         @relation(fields: [cashAccountId], references: [id], onDelete: Cascade)
  category      Category            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  transfer      CashTransfer?       @relation(fields: [transferId], references: [id], onDelete: Cascade)
  funding       AccountFunding?     @relation(fields: [fundingId], references: [id], onDelete: Cascade)
  relatedExpense Transaction?       @relation("TransactionReimbursements", fields: [relatedExpenseId], references: [id], onDelete: SetNull)
  reimbursements Transaction[]      @relation("TransactionReimbursements")

  @@index([cashAccountId])
  @@index([categoryId])
  @@index([date])
  @@index([type])
  @@index([transferId])
  @@index([fundingId])
  @@index([relatedExpenseId])
}

model CashTransfer {
  id                String      @id @default(cuid())
  userId            String
  fromCashAccountId String
  toCashAccountId   String
  amount            Float
  date              DateTime
  description       String?
  createdAt         DateTime    @default(now())
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAccount       CashAccount @relation("TransferOut", fields: [fromCashAccountId], references: [id], onDelete: Cascade)
  toAccount         CashAccount @relation("TransferIn", fields: [toCashAccountId], references: [id], onDelete: Cascade)
  transactions      Transaction[]

  @@index([userId])
  @@index([fromCashAccountId])
  @@index([toCashAccountId])
  @@index([date])
}

model AccountFunding {
  id                  String      @id @default(cuid())
  userId              String
  type                FundingType
  cashAccountId       String
  investmentAccountId String
  amount              Float
  date                DateTime
  description         String?
  createdAt           DateTime    @default(now())
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cashAccount         CashAccount @relation(fields: [cashAccountId], references: [id], onDelete: Cascade)
  investmentAccount   Account     @relation(fields: [investmentAccountId], references: [id], onDelete: Cascade)
  transactions        Transaction[]
  movements           Movement[]

  @@index([userId])
  @@index([cashAccountId])
  @@index([investmentAccountId])
  @@index([date])
  @@index([type])
}

model Budget {
  id            String           @id @default(cuid())
  userId        String
  cashAccountId String?
  name          String
  amount        Float
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  cashAccount   CashAccount?     @relation(fields: [cashAccountId], references: [id], onDelete: Cascade)
  categories    BudgetCategory[]

  @@index([userId])
  @@index([cashAccountId])
  @@index([startDate])
  @@index([endDate])
}

model BudgetCategory {
  budgetId   String
  categoryId String
  budget     Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([budgetId, categoryId])
  @@index([categoryId])
}
