{
  "name": "fci-backend",
  "version": "1.0.0",
  "description": "Backend REST para seguimiento y simulación de inversiones personales",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "lint": "tsc --noEmit",
    "start:migrate": "prisma migrate deploy && node dist/server.js",
    "render:build": "npm install && prisma generate && tsup",
    "postinstall": "prisma generate",
    "start:prod": "prisma migrate deploy && node dist/server.js"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "fci",
    "investments",
    "fastify",
    "prisma"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.2",
    "@prisma/client": "^6.9.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.0.1",
    "prisma": "^6.9.0",
    "telegraf": "^4.16.3",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.15.30",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
